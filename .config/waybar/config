{
    "layer": "top", // Waybar at top layer
    "height": 30, // Waybar height (to be removed for auto height)
    "spacing": 4, // Gaps between modules (4px)
    "modules-left": ["hyprland/workspaces", "custom/waybarstatus"],
    "modules-center": ["custom/aside", "custom/ccl", "custom/recording", "custom/external-drive", "custom/bluetooth", "custom/audio", "custom/voice-typing"],
    "modules-right": ["custom/emacs-daemon", "custom/notification", "tray", "custom/sysinfo", "network", "battery", "custom/system-freshness", "custom/gcal", "clock", "custom/swaync-open"],
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "яАг",
            "unlocked": "яВЬ"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "яЛТ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) т╕и{songPosition}|{queueLength}т╕й {volume}% яАБ",
        "format-disconnected": "Disconnected яАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped яАБ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "яГД "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">яБ┤</span> ",
            "on": "яБ┤ "
        },
        "repeat-icons": {
            "on": "яАЮ "
        },
        "single-icons": {
            "on": "яАЮ1 "
        },
        "state-icons": {
            "paused": "яБМ",
            "playing": "яБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "timezones": ["", "UTC"],
        "tooltip-format": "{tz_list}",
        "timezone-tooltip-format": "UTC: {:%H:%M:%S}",
        "format-alt": "{:%m/%d at %H:%M}",
        "format": "{:%m/%d at %H:%M:%S}",
        "interval": 1,
    },
    "cpu": {
        "format": "{usage}% яЛЫ",
        "tooltip": false
    },
    "custom/sysinfo": {
        "exec": "sysinfo-status",
        "return-type": "json",
        "interval": 3,
        "tooltip": true,
        "on-click": "sysinfo-cycle",
        "on-click-right": "foot -e top",
        "on-click-middle": "sysinfo-top"
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
    },
    "battery": {
        "states": {
            "warning": 15,
            "critical": 8
        },
        "format": "{icon}",
        "format-charging": "юд╣",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{capacity}% {icon}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        "format-wifi": "{essid} яЗл",
        "format-ethernet": "{ipaddr}/{cidr} юв╛",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP) ",
        "format-disconnected": "Disconnected тЪа",
        "format-alt": "-"
    },
    "custom/audio": {
        "exec": "audio-status",
        "return-type": "json",
        "interval": 2,
        "signal": 14,
        "tooltip": true,
        "on-click": "sleep 0.1 && foot --app-id=fzf-picker -e audio-switcher",
        "on-click-right": "sleep 0.1 && foot --app-id=fzf-picker -e audio-mixer",
        "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle && pkill -RTMIN+14 waybar",
        "on-scroll-up": "audio-volume up && pkill -RTMIN+14 waybar",
        "on-scroll-down": "audio-volume down && pkill -RTMIN+14 waybar"
    },
    "custom/bluetooth": {
        "exec": "bluetooth-status",
        "return-type": "json",
        "interval": 5,
        "signal": 15,
        "tooltip": true,
        "on-click": "sleep 0.1 && foot --app-id=fzf-picker -e bluetooth-picker",
        "on-click-right": "foot -e bluetoothctl"
    },
    "custom/waybarstatus": {
        "exec": "waybar-status",
        "interval": 1,
        "return-type": "html",
        "tooltip": "This is my custom module.",
    },
        "custom/vpn": {
        "interval": 1,
        "format": "VPN",
        "return-type": "html",
        "tooltip": "Connect to ifit vpn",
        "on-click": "start-ifit-vpn-session"
    },
        "custom/mywidget": {
        "interval": 5,
        "format": "╬╗",
        "return-type": "json",
        "on-click": "log_message 'all trees will fall someday but not us' && sleep 2 && log_message"
    },
    "custom/keybinds": {
        "format": "ґ░ММ",
        "tooltip": "Show keybinds",
        "on-click": "foot --app-id=fzf-picker -e show-keybinds"
    },
    "custom/emacs-dired": {
        "format": "ЁЯУВ",
        "tooltip": "Open Emacs Dired",
        "on-click": "emacsclient -c -e '(dired \"~/\")'",
        "return-type": "json"
    },
    "custom/recording": {
        "exec": "record-status",
        "return-type": "json",
        "interval": 1,
        "signal": 13
    },
    "custom/external-drive": {
        "exec": "external-drive-status",
        "interval": 2,
        "return-type": "json",
        "tooltip": true,
        "on-click": "open-external-drive"
    },
    "custom/swaync-open": {
        "format": "ґ░ЪЕ",
        "tooltip": "Open Notification Center",
        "on-click": "swaync-client -t -sw"
    },
    "custom/voice-typing": {
        "exec": "voice-typing-status",
        "return-type": "json",
        "interval": 1,
        "on-click": "voice-typing"
    },
    "custom/emacs-daemon": {
        "exec": "emacs-daemon-status",
        "return-type": "json",
        "interval": 5,
        "tooltip": true
    },
    "custom/aside": {
        "exec": "aside-waybar-status",
        "return-type": "json",
        "interval": 2,
        "on-click": "aside query --mic",
        "on-click-right": "aside-input",
        "on-click-middle": "aside speak",
        "on-scroll-up": "aside-model-cycle up",
        "on-scroll-down": "aside-model-cycle down",
        "signal": 12,
        "tooltip": true
    },
    "custom/ccl": {
        "exec": "ccl-waybar-status",
        "return-type": "json",
        "interval": 2,
        "on-click": "foot --app-id=fzf-picker -e ccl ui",
        "on-click-right": "foot --app-id=fzf-picker -e ccl-worker-new",
        "signal": 12,
        "tooltip": true
    },
    "custom/system-freshness": {
        "exec": "system-freshness",
        "return-type": "json",
        "interval": 60,
        "signal": 10,
        "on-click": "system-freshness-update",
        "on-click-right": "system-freshness-details",
        "tooltip": true
    },
    "custom/gcal": {
        "exec": "gcal-status",
        "return-type": "json",
        "interval": 30,
        "signal": 11,
        "on-click": "gcal-popup",
        "on-click-middle": "gcal-dismiss",
        "on-click-right": "xdg-open https://calendar.google.com",
        "tooltip": true
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "<span foreground='red'><sup></sup></span>",
            "none": "",
            "dnd-notification": "",
            "dnd-none": "",
            "inhibited-notification": "",
            "inhibited-none": ""
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    }
}

#!/bin/bash
# Extract Anthropic API key from authinfo.gpg and write to aside's
# runtime cache. Called by ExecStartPre so the daemon finds the key
# via _restore_api_keys() on startup.

CACHE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/aside-api-keys"

# If cache already exists (from a previous boot session or manual set), skip
if [ -f "$CACHE" ]; then
    exit 0
fi

KEY=$(gpg --batch --quiet --decrypt ~/.authinfo.gpg 2>/dev/null \
    | awk '/machine api.anthropic.com/{for(i=1;i<=NF;i++)if($i=="password")print $(i+1)}')

if [ -n "$KEY" ]; then
    printf '{"ANTHROPIC_API_KEY": "%s"}' "$KEY" > "${CACHE}.tmp"
    chmod 600 "${CACHE}.tmp"
    mv "${CACHE}.tmp" "$CACHE"
fi

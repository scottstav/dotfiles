#!/bin/bash
# Bluetooth quick-connect TUI — fzf in foot
# Select a paired device to toggle connect/disconnect
# Or scan for new devices

source ~/.local/share/fzf-picker/theme.sh

bold=$'\e[1m'
dim=$'\e[2m'
reset=$'\e[0m'
green=$'\e[32m'
red=$'\e[31m'
cyan=$'\e[36m'
yellow=$'\e[33m'

# D-Bus helpers
bt_prop() { busctl get-property org.bluez "$1" "$2" "$3" 2>/dev/null; }
bt_call() { busctl call --timeout=15 org.bluez "$@" 2>&1; }

# Check controller
powered=$(bt_prop /org/bluez/hci0 org.bluez.Adapter1 Powered | awk '{print $2}')
if [[ "$powered" != "true" ]]; then
    echo "${red}Bluetooth is off${reset}" | fzf \
        "${FZF_PICKER_OPTS[@]}" --ansi \
        --header="${bold}Bluetooth${reset}" \
        --bind 'enter:execute-silent(busctl set-property org.bluez /org/bluez/hci0 org.bluez.Adapter1 Powered b true)+abort'
    exit
fi

# List paired devices
list_devices() {
    for devpath in $(busctl tree org.bluez 2>/dev/null | grep -oP '/org/bluez/hci0/dev_[A-F0-9_]+' | sort -u); do
        name=$(bt_prop "$devpath" org.bluez.Device1 Alias | sed 's/^s "//;s/"$//')
        [[ -z "$name" ]] && continue
        paired=$(bt_prop "$devpath" org.bluez.Device1 Paired | awk '{print $2}')
        [[ "$paired" != "true" ]] && continue
        connected=$(bt_prop "$devpath" org.bluez.Device1 Connected | awk '{print $2}')
        battery=$(bt_prop "$devpath" org.bluez.Battery1 Percentage | awk '{print $2}')
        icon=$(bt_prop "$devpath" org.bluez.Device1 Icon | sed 's/^s "//;s/"$//')
        mac=$(basename "$devpath" | sed 's/dev_//' | tr '_' ':')

        if [[ "$connected" == "true" ]]; then
            marker="${green}*${reset}"
            status="${green}connected${reset}"
        else
            marker="${dim}o${reset}"
            status="${dim}disconnected${reset}"
        fi

        bat_str=""
        if [[ -n "$battery" ]]; then
            if (( battery <= 20 )); then
                bat_str="  ${red}${battery}%${reset}"
            else
                bat_str="  ${battery}%"
            fi
        fi

        case "$icon" in
            audio-headset|audio-headphones) dev_icon="H" ;;
            input-mouse)                    dev_icon="M" ;;
            input-keyboard)                 dev_icon="K" ;;
            *)                              dev_icon=" " ;;
        esac

        printf "%s %s ${bold}%-24s${reset} %s%s\t%s\t%s\n" \
            "$marker" "$dev_icon" "$name" "$status" "$bat_str" "$mac" "$connected"
    done
}

# Scan and list unpaired devices (progress to stderr, devices to stdout)
scan_and_list() {
    echo "${cyan}Scanning for devices (8s)...${reset}" >&2
    bt_call /org/bluez/hci0 org.bluez.Adapter1 StartDiscovery >/dev/null 2>&1
    sleep 8
    bt_call /org/bluez/hci0 org.bluez.Adapter1 StopDiscovery >/dev/null 2>&1

    for devpath in $(busctl tree org.bluez 2>/dev/null | grep -oP '/org/bluez/hci0/dev_[A-F0-9_]+' | sort -u); do
        name=$(bt_prop "$devpath" org.bluez.Device1 Alias | sed 's/^s "//;s/"$//')
        [[ -z "$name" ]] && continue
        paired=$(bt_prop "$devpath" org.bluez.Device1 Paired | awk '{print $2}')
        [[ "$paired" == "true" ]] && continue
        mac=$(basename "$devpath" | sed 's/dev_//' | tr '_' ':')
        # Skip if name is just the MAC (no real name advertised)
        [[ "$name" == "$mac" ]] && continue
        # Skip names with non-printable junk
        printable=$(echo "$name" | tr -cd '[:print:]')
        (( ${#printable} < ${#name} / 2 )) && continue

        printf "${dim}o${reset}  ${bold}%-24s${reset} ${dim}new${reset}\t%s\tnew\n" "$name" "$mac"
    done
}

# Main picker
while true; do
    devices=$(list_devices)

    scan_line="${cyan}~ Scan for new devices${reset}\t__scan__\tfalse"
    all_items="$devices"
    [[ -n "$all_items" ]] && all_items="$all_items"$'\n'"$scan_line" || all_items="$scan_line"

    selection=$(echo "$all_items" | fzf \
        "${FZF_PICKER_OPTS[@]}" --ansi \
        --header="${bold}Bluetooth${reset}  ${dim}enter: connect/disconnect${reset}" \
        --delimiter=$'\t' --with-nth=1 \
        --bind 'left-click:accept' \
        --bind 'esc:abort')

    [[ $? -ne 0 || -z "$selection" ]] && break

    mac=$(printf '%s' "$selection" | awk -F'\t' '{print $2}')
    was_connected=$(printf '%s' "$selection" | awk -F'\t' '{print $3}')

    if [[ "$mac" == "__scan__" ]]; then
        new_devices=$(scan_and_list)

        if [[ -n "$new_devices" ]]; then
            pair_selection=$(echo "$new_devices" | fzf \
                "${FZF_PICKER_OPTS[@]}" --ansi \
                --header="${bold}Pair new device${reset}" \
                --delimiter=$'\t' --with-nth=1 \
                --bind 'left-click:accept' \
                --bind 'esc:abort')

            if [[ -n "$pair_selection" ]]; then
                pair_mac=$(printf '%s' "$pair_selection" | awk -F'\t' '{print $2}')
                devpath="/org/bluez/hci0/dev_${pair_mac//:/_}"
                echo "${cyan}Pairing...${reset}"
                bt_call "$devpath" org.bluez.Device1 Pair
                busctl set-property org.bluez "$devpath" org.bluez.Device1 Trusted b true 2>/dev/null
                echo "${cyan}Connecting...${reset}"
                bt_call "$devpath" org.bluez.Device1 Connect
                sleep 1
            fi
        else
            echo "${dim}No new devices found${reset}"
            sleep 1
        fi
        pkill -RTMIN+15 waybar 2>/dev/null
        continue
    fi

    # Toggle connect/disconnect — synchronous, errors visible
    devpath="/org/bluez/hci0/dev_${mac//:/_}"
    if [[ "$was_connected" == "true" ]]; then
        echo "${yellow}Disconnecting...${reset}"
        result=$(bt_call "$devpath" org.bluez.Device1 Disconnect)
    else
        echo "${cyan}Connecting...${reset}"
        result=$(bt_call "$devpath" org.bluez.Device1 Connect)
    fi

    if [[ -n "$result" && ( "$result" == *"rror"* || "$result" == *"ailed"* || "$result" == *"imeout"* ) ]]; then
        echo "${red}${result}${reset}"
        sleep 2
    else
        sleep 1
    fi
    pkill -RTMIN+15 waybar 2>/dev/null
done

#!/bin/bash
# Show completion notification with resume action — called from ccl on_done hook
# Usage: ccl-done-notify <id> <session_id> <directory>

id="$1"
session_id="$2"
dir="$3"

[[ -z "$id" || -z "$dir" ]] && exit 1

dir_short="${dir/#$HOME/\~}"

# Show log tail as preview
log_file="$HOME/.local/state/ccl/$id.log"
result_preview="(no output)"
if [[ -f "$log_file" ]]; then
    result_preview=$(tail -c 500 "$log_file")
fi

action=$(notify-send -t 0 -a "ccl" \
    -A "resume=Resume" -A "dismiss=OK" \
    --wait \
    "Worker Done ($dir_short)" "$result_preview" 2>/dev/null)

if [[ "$action" == "resume" && -n "$session_id" ]]; then
    hyprctl dispatch exec "alacritty --working-directory '$dir' -e ccl resume '$id'"
fi

#!/bin/bash
# Waybar module for ccl worker status

ICON=$'\U000f0710' # 󰜐
ts=$(date +%H:%M:%S)

json=$(ccl list --json 2>/dev/null) || json=""

# If empty, non-JSON, or "No workers." text — idle
if [[ -z "$json" ]] || ! echo "$json" | jq empty 2>/dev/null; then
    echo "{\"text\": \"$ICON\", \"tooltip\": \"No workers ($ts)\", \"class\": \"idle\"}"
    exit 0
fi

read -r total pending working done_count error_count css < <(
    echo "$json" | jq -r '
        . as $w |
        ($w | length) as $total |
        ([$w[] | select(.status=="pending")] | length) as $pending |
        ([$w[] | select(.status=="working")] | length) as $working |
        ([$w[] | select(.status=="done")] | length) as $done |
        ([$w[] | select(.status=="error")] | length) as $error |
        (if $working > 0 then "working"
         elif $error > 0 then "error"
         elif $done > 0 then "done"
         elif $pending > 0 then "pending"
         else "idle" end) as $css |
        "\($total) \($pending) \($working) \($done) \($error) \($css)"
    '
)

if [[ "$total" -eq 0 ]]; then
    echo "{\"text\": \"$ICON\", \"tooltip\": \"No workers ($ts)\", \"class\": \"idle\"}"
    exit 0
fi

# Build tooltip
parts=()
[[ "$pending" -gt 0 ]] && parts+=("$pending pending")
[[ "$working" -gt 0 ]] && parts+=("$working working")
[[ "$done_count" -gt 0 ]] && parts+=("$done_count done")
[[ "$error_count" -gt 0 ]] && parts+=("$error_count error")
tooltip="Workers: $(IFS=', '; echo "${parts[*]}") ($ts)"

echo "{\"text\": \"$ICON $total\", \"tooltip\": \"$tooltip\", \"class\": \"$css\"}"

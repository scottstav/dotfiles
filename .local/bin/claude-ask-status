#!/bin/bash
# Waybar module for claude-ask status — two-zone display

STATE_FILE="$HOME/.local/state/claude-ask/waybar.json"

if [ ! -f "$STATE_FILE" ]; then
    echo '{"text": "\uee0d", "class": "idle", "tooltip": "Claude Ask (not running)"}'
    exit 0
fi

python3 -c "
import json, glob, os
from datetime import datetime

d = json.load(open('$STATE_FILE'))
status = d.get('status', 'idle')
speak = d.get('speak_enabled', False)
wake_muted = d.get('wake_muted', False)
tool_name = d.get('tool_name', '')
model_id = d.get('model', 'claude-sonnet-4-6')
usage = d.get('usage', {})

MODEL_NAMES = {
    'claude-haiku-4-5': 'Haiku',
    'claude-sonnet-4-6': 'Sonnet',
    'claude-opus-4-6': 'Opus',
}
model_short = MODEL_NAMES.get(model_id, model_id)
month = usage.get('month_cost', '\$0.00')
last = usage.get('last_query_cost', '\$0.00')

# Read worker state files
worker_dir = os.path.expanduser('~/.local/state/claude-worker')
workers = []
for f in glob.glob(os.path.join(worker_dir, '*.json')):
    try:
        workers.append(json.load(open(f)))
    except (json.JSONDecodeError, IOError):
        pass

worker_pending = sum(1 for w in workers if w.get('status') == 'pending')
worker_working = sum(1 for w in workers if w.get('status') == 'working')
worker_done = sum(1 for w in workers if w.get('status') == 'done')
worker_total = worker_pending + worker_working + worker_done
worker_state = 'working' if worker_working > 0 else ('done' if worker_done > 0 else ('pending' if worker_pending > 0 else None))

# Persistent icon
mode_icon = '\uee0d'  #  claude
SHOVEL = '\U000f0710'  # 󰜐
LAVENDER = '#b4befe'
YELLOW = '#f9e2af'
GREEN = '#a6e3a1'
DIM = '#585b70'

# Activity indicator: only when not idle
activity_icons = {
    'thinking':  '\U000f0674',  # 󰙴 creation (sparkle)
    'tool_use':  '\U000f0493',  # 󰒓 cog
    'speaking':  '\U000f057e',  # 󰕾 volume_high
    'listening': '\U000f036c',  # 󰍬 microphone
}

is_active = status != 'idle' and status in activity_icons

# Build shovel suffix
shovel_suffix = ''
if worker_state:
    count_str = f' {worker_total}' if worker_total > 1 else ''
    if is_active:
        # Static Pango color — CSS drives the activity indicator
        shovel_color = YELLOW if worker_state == 'working' else (GREEN if worker_state == 'done' else DIM)
        shovel_suffix = f' <span foreground=\"{shovel_color}\">{SHOVEL}{count_str}</span>'
    else:
        # Inherits CSS animation color
        shovel_suffix = f' {SHOVEL}{count_str}'

if is_active:
    activity = activity_icons[status]
    if status == 'tool_use' and tool_name:
        activity += f' {tool_name}'
    icon = f'<span foreground=\"{LAVENDER}\">{mode_icon} \ue0b0</span> {activity}{shovel_suffix}'
elif worker_state:
    # Idle + worker active: pin robot to lavender, shovel inherits CSS
    icon = f'<span foreground=\"{LAVENDER}\">{mode_icon}</span>{shovel_suffix}'
else:
    icon = mode_icon

# CSS class
if is_active:
    css = status
elif worker_state == 'working':
    css = 'worker-working'
elif worker_state == 'done':
    css = 'worker-done'
elif worker_state == 'pending':
    css = 'worker-pending'
else:
    css = status

# Tooltip
month_name = datetime.now().strftime('%b')
if status == 'tool_use' and tool_name:
    tip = f'Running: {tool_name}'
elif status == 'thinking':
    tip = 'Thinking...'
elif status == 'speaking':
    tip = 'Speaking... (mid-click to stop)'
elif status == 'listening':
    tip = 'Listening...'
else:
    tip = f'{model_short} | {month_name}: {month} | Last: {last}'
    tip += ' | Voice: ON' if speak else ' | Voice: OFF'
    tip += ' | Wake: OFF' if wake_muted else ' | Wake: ON'

if worker_state:
    parts = []
    if worker_pending: parts.append(f'{worker_pending} pending')
    if worker_working: parts.append(f'{worker_working} working')
    if worker_done: parts.append(f'{worker_done} done')
    tip += ' | Workers: ' + ', '.join(parts)

print(json.dumps({'text': icon, 'tooltip': tip, 'class': css}, ensure_ascii=False))
"

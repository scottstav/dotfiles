#!/bin/bash
# Toggle claude-voice wake word muting on/off

SOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/claude-voice.sock"
STATE_FILE="$HOME/.local/state/claude-ask/waybar.json"

if [ ! -S "$SOCK" ]; then
    notify-send "Claude Voice" "Not running" -i dialog-warning
    exit 1
fi

# Send toggle-mute to claude-voice daemon and read back new state
response=$(python3 -c "
import socket, json
sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
sock.connect('$SOCK')
sock.sendall(json.dumps({'action': 'toggle-mute'}).encode())
sock.shutdown(socket.SHUT_WR)
data = sock.recv(4096)
sock.close()
print(data.decode())
" 2>/dev/null)

muted=$(echo "$response" | python3 -c "import json,sys; print(json.load(sys.stdin).get('muted', False))" 2>/dev/null)

# Update waybar state file so the status script reflects it
python3 -c "
import json
path = '$STATE_FILE'
try:
    with open(path) as f:
        d = json.load(f)
except (FileNotFoundError, json.JSONDecodeError):
    d = {}
d['wake_muted'] = $([[ "$muted" == "True" ]] && echo "True" || echo "False")
with open(path, 'w') as f:
    json.dump(d, f, indent=2)
"

# Signal Waybar to refresh
pkill -SIGRTMIN+12 waybar 2>/dev/null

if [[ "$muted" == "True" ]]; then
    notify-send "Claude Voice" "Wake word disabled" -i microphone-sensitivity-muted -t 2000
else
    notify-send "Claude Voice" "Wake word enabled" -i microphone-sensitivity-high -t 2000
fi

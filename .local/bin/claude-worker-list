#!/bin/bash
# Show fzf picker of workers. Runs inside foot (launched by waybar).

# Guard: if no TTY, re-exec inside foot
if [[ ! -t 0 ]]; then
    exec foot --app-id=fzf-picker -e "$0" "$@"
fi

STATE_DIR="$HOME/.local/state/claude-worker"

# Pre-scan: clean stale "working" workers (dead PID)
cleaned=0
for f in "$STATE_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    status=$(jq -r '.status' "$f")
    if [[ "$status" == "working" ]]; then
        pid=$(jq -r '.pid // empty' "$f")
        if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$f"
            ((cleaned++))
        fi
    fi
done
if [[ $cleaned -gt 0 ]]; then
    pkill -SIGRTMIN+12 waybar
    echo "Cleaned $cleaned stale worker(s)."
fi

# Build list of workers
entries=()
ids=()
for f in "$STATE_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    id=$(basename "$f" .json)
    status=$(jq -r '.status' "$f")
    dir=$(jq -r '.directory' "$f" | sed "s|$HOME|~|")
    task=$(jq -r '.task' "$f" | head -c 60)
    image=$(jq -r '.image // empty' "$f")
    img_tag=""
    [[ -n "$image" ]] && img_tag=" 📎"

    case "$status" in
        pending) icon="⏳" ;;
        working) icon="⚒️" ;;
        done)    icon="✅" ;;
        *)       icon="?" ;;
    esac
    entries+=("$icon $status | $dir | $task$img_tag")
    ids+=("$id:$status")
done

if [[ ${#entries[@]} -eq 0 ]]; then
    [[ $cleaned -gt 0 ]] && echo "No active workers remain."
    echo "No workers."
    sleep 0.8
    exit 0
fi

# Show fzf picker
selected=$(printf '%s\n' "${entries[@]}" | fzf \
    --ansi --height=100% --layout=reverse \
    --header="⏳ approve  ⚒️/✅ resume in alacritty" \
    --no-info --pointer=">" --no-scrollbar)
[[ -z "$selected" ]] && exit 0

# Find which entry was selected
for i in "${!entries[@]}"; do
    if [[ "${entries[$i]}" == "$selected" ]]; then
        IFS=: read -r sel_id sel_status <<< "${ids[$i]}"
        break
    fi
done

state_file="$STATE_DIR/$sel_id.json"

case "$sel_status" in
    pending)
        claude-worker-manage "$sel_id"
        ;;
    working|done)
        session_id=$(jq -r '.session_id // empty' "$state_file")
        dir=$(jq -r '.directory' "$state_file")

        # Kill session script + claude process if still running
        for key in session_pid pid; do
            p=$(jq -r ".$key // empty" "$state_file")
            [[ -n "$p" ]] && kill "$p" 2>/dev/null
        done

        rm -f "$state_file" "$STATE_DIR/$sel_id.log"
        pkill -SIGRTMIN+12 waybar

        if [[ -n "$session_id" ]]; then
            hyprctl dispatch exec "env -u CLAUDECODE alacritty --working-directory '$dir' -e claude --dangerously-skip-permissions --resume '$session_id'"
        else
            echo "No session to resume. Cleaned up."
            sleep 1
        fi
        ;;
esac

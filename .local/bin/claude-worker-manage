#!/bin/bash
# Manage pending Claude Worker requests — approve or deny via ccl
# Usage:
#   claude-worker-manage <id>          # approve: launch worker session
#   claude-worker-manage --deny <id>   # deny: remove pending state file

usage() {
    echo "Usage:" >&2
    echo "  claude-worker-manage <id>          # approve pending worker" >&2
    echo "  claude-worker-manage --deny <id>   # deny pending worker" >&2
    exit 1
}

# Parse arguments
DENY=false
if [[ "$1" == "--deny" ]]; then
    DENY=true
    shift
fi

ID="$1"
[[ -z "$ID" ]] && usage

if $DENY; then
    ccl deny "$ID"
else
    ccl approve "$ID"
fi

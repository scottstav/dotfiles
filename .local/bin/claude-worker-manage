#!/bin/bash
# Manage pending Claude Worker requests — approve or deny
# Usage:
#   claude-worker-manage <id>          # approve: launch worker session
#   claude-worker-manage --deny <id>   # deny: remove pending state file

STATE_DIR="$HOME/.local/state/claude-worker"

usage() {
    echo "Usage:"
    echo "  claude-worker-manage <id>          # approve pending worker"
    echo "  claude-worker-manage --deny <id>   # deny pending worker"
    exit 1
}

# Parse arguments
DENY=false
if [[ "$1" == "--deny" ]]; then
    DENY=true
    shift
fi

ID="$1"
[[ -z "$ID" ]] && usage

STATE_FILE="$STATE_DIR/$ID.json"

if [[ ! -f "$STATE_FILE" ]]; then
    echo "Error: no state file found for worker $ID"
    exit 1
fi

# Read and validate state
status=$(jq -r '.status' "$STATE_FILE")
if [[ "$status" != "pending" ]]; then
    echo "Error: worker $ID is not pending (status: $status)"
    exit 1
fi

if $DENY; then
    # Deny: remove state file and signal waybar
    rm -f "$STATE_FILE"
    pkill -SIGRTMIN+12 waybar
    echo "Denied worker $ID"
else
    # Approve: read task details and launch session
    dir=$(jq -r '.directory' "$STATE_FILE")
    task=$(jq -r '.task' "$STATE_FILE")

    hyprctl dispatch exec -- \
        "foot --app-id=claude-worker-$ID -- claude-worker-session '$ID' '$dir' '$task'"

    echo "Approved worker $ID → $dir"
fi

#!/bin/bash
# Interactive new worker setup — runs inside foot (fzf-picker)
# Picks a directory and task, then spawns a background worker via ccl

HISTORY_FILE="$HOME/.local/state/ccl/dir-history"
mkdir -p "$(dirname "$HISTORY_FILE")"

# Pick directory with fzf (recent selections first)
dir=$(
    {
        [[ -f "$HISTORY_FILE" ]] && tac "$HISTORY_FILE" | awk '!seen[$0]++'
        fd -t d -H '^\.git$' -d 4 ~ --prune | sed 's/\.git\/$//' | sort
    } | awk '!seen[$0]++' | fzf --prompt="  Directory: " --height=100% --layout=reverse
)
[[ -z "$dir" ]] && exit 0
echo "$dir" >> "$HISTORY_FILE"

# Prompt for task (readline enabled for arrow keys, ctrl+b/f, alt+f/b, etc.)
read -e -r -p "  Task: " task
[[ -z "$task" ]] && exit 0

# Optional image path (tab-completes filenames via readline)
read -e -r -p "  Image (optional): " image_path
# Resolve relative paths and validate
if [[ -n "$image_path" ]]; then
    image_path=$(realpath -q "$image_path" 2>/dev/null || echo "$image_path")
    if [[ ! -f "$image_path" ]]; then
        echo "  Warning: file not found: $image_path"
        read -r -p "  Continue anyway? [y/N] " yn
        [[ "$yn" != [yY]* ]] && exit 0
    fi
fi

# Build ccl new command
cmd=(ccl new --dir "$dir" --task "$task")
[[ -n "$image_path" ]] && cmd+=(--image "$image_path")

ID=$("${cmd[@]}")
if [[ $? -eq 0 ]]; then
    echo "Worker $ID started in background."
else
    echo "Failed to create worker."
fi
sleep 0.3

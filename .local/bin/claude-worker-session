#!/bin/bash
# Claude Worker session — runs as background daemon (no terminal)
# Usage: claude-worker-session <id> [<dir> <task>]
#   With just <id>, reads directory and task from the state file.

ID="$1"
[[ -z "$ID" ]] && { echo "Usage: claude-worker-session <id> [<dir> <task>]" >&2; exit 1; }

STATE_DIR="$HOME/.local/state/claude-worker"
STATE_FILE="$STATE_DIR/$ID.json"
LOG_FILE="$STATE_DIR/$ID.log"
mkdir -p "$STATE_DIR"

if [[ -n "$2" && -n "$3" ]]; then
    dir="$2"
    task="$3"
elif [[ -f "$STATE_FILE" ]]; then
    dir=$(jq -r '.directory' "$STATE_FILE")
    task=$(jq -r '.task' "$STATE_FILE")
else
    echo "Error: no state file for worker $ID and no dir/task args" >&2
    exit 1
fi

[[ -z "$dir" || -z "$task" ]] && { echo "Error: empty directory or task" >&2; exit 1; }

# Prevent "nested session" error — workers are independent
unset CLAUDECODE

# EXIT trap: clean up only if still "working" (abnormal exit)
cleanup() {
    if [[ -f "$STATE_FILE" ]] && [[ "$(jq -r '.status' "$STATE_FILE" 2>/dev/null)" == "working" ]]; then
        rm -f "$STATE_FILE" "$LOG_FILE"
        pkill -SIGRTMIN+12 waybar
    fi
}
trap cleanup EXIT

# Generate a session ID for resume
SESSION_ID=$(uuidgen)

cd "$dir" || exit 1

# Run claude in print mode, log output for debugging
claude -p --dangerously-skip-permissions \
    --append-system-prompt "You are the user's trusted programmer. You do not have to ask approval for plans. You should not ask questions. You should do the desired task and do not stop until the task is done. Complete the entire task before stopping. Do not summarize remaining work or suggest the user finish manually. If you encounter issues, debug and fix them. Only stop when the task is fully done. When finished, end with a 1-2 sentence summary of what you did." \
    --session-id "$SESSION_ID" "$task" \
    </dev/null >"$LOG_FILE" 2>&1 &
CLAUDE_PID=$!

# Write working state (include session PID so list can kill the whole thing)
jq -n --arg dir "$dir" --arg task "$task" --arg pid "$CLAUDE_PID" --arg spid "$$" --arg sid "$SESSION_ID" \
    '{"status": "working", "directory": $dir, "task": $task, "pid": ($pid|tonumber), "session_pid": ($spid|tonumber), "session_id": $sid}' > "$STATE_FILE"
pkill -SIGRTMIN+12 waybar

wait $CLAUDE_PID

# Update state to done (EXIT trap won't delete it since status is no longer "working")
jq -n --arg dir "$dir" --arg task "$task" --arg sid "$SESSION_ID" \
    '{"status": "done", "directory": $dir, "task": $task, "session_id": $sid}' > "$STATE_FILE"
pkill -SIGRTMIN+12 waybar

# Notify completion with last output from the session
result_preview="(no output)"
if [[ -f "$LOG_FILE" ]]; then
    result_preview=$(tail -c 500 "$LOG_FILE")
fi
action=$(notify-send -t 0 -a "Claude Worker" \
    -A "resume=Resume" -A "dismiss=OK" \
    --wait \
    "Worker Done" "$result_preview" 2>/dev/null)

if [[ "$action" == "resume" ]]; then
    hyprctl dispatch exec "env -u CLAUDECODE alacritty --working-directory '$dir' -e claude --dangerously-skip-permissions --resume '$SESSION_ID'"
fi

# Clean up state and log
rm -f "$STATE_FILE" "$LOG_FILE"
pkill -SIGRTMIN+12 waybar

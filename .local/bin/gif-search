#!/bin/bash
# gif-search — Klipy GIF API search helper for gif-picker
# Usage: gif-search <query>

[[ -z "$1" ]] && exit 0

API_KEY_FILE="$HOME/.config/gif-picker/api-key"
[[ ! -f "$API_KEY_FILE" ]] && { echo "Missing API key at $API_KEY_FILE"; exit 1; }
API_KEY=$(< "$API_KEY_FILE")

QUERY=$(printf '%s' "$1" | jq -sRr @uri)

curl -sf "https://api.klipy.com/api/v1/${API_KEY}/gifs/search?q=${QUERY}&page=1&per_page=20&content_filter=moderate&format_filter=gif" \
  | jq -r '.data.data[]? | [.title, .file.hd.gif.url, .file.sm.gif.url] | @tsv'

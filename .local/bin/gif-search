#!/bin/bash
# gif-search — Tenor v2 search helper for gif-picker
# Usage: gif-search <query>

[[ -z "$1" ]] && exit 0

API_KEY_FILE="$HOME/.config/gif-picker/api-key"
[[ ! -f "$API_KEY_FILE" ]] && { echo "Missing API key at $API_KEY_FILE"; exit 1; }
API_KEY=$(< "$API_KEY_FILE")

QUERY=$(printf '%s' "$1" | jq -sRr @uri)

curl -sf "https://tenor.googleapis.com/v2/search?q=${QUERY}&key=${API_KEY}&client_key=gif-picker&limit=20&media_filter=gif,tinygif" \
  | jq -r '.results[] | [.content_description, .media_formats.gif.url, .media_formats.tinygif.url] | @tsv'

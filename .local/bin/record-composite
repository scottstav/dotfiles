#!/bin/bash
# Composite webcam overlay onto screen recording.
# Usage: record-composite SCREEN_FILE WEBCAM_FILE OUTPUT

screen="$1"
webcam="$2"
output="$3"

if [[ ! -f "$screen" ]] || [[ ! -s "$screen" ]]; then
    notify-send "Recording failed" "Screen capture missing or empty" -i dialog-error
    rm -f "$screen" "$webcam"
    exit 1
fi

if [[ -f "$webcam" ]]; then
    screen_w=$(ffprobe -v error -select_streams v:0 \
        -show_entries stream=width -of csv=p=0 "$screen")
    d=$(( (screen_w / 6 + 1) / 2 * 2 ))  # round to even (yuv420p requires it)
    r=$(( d / 2 ))
    pad=20

    # Pre-generate a static circle mask instead of running geq per frame
    mask="/tmp/record-mask-$$.png"
    ffmpeg -f lavfi -i "color=white:s=${d}x${d},format=gray,geq=lum='if(lt(pow(X-${r},2)+pow(Y-${r},2),pow(${r},2)),255,0)'" \
        -frames:v 1 -y "$mask" 2>/dev/null

    ffmpeg -y -i "$screen" -i "$webcam" -stream_loop -1 -i "$mask" -filter_complex "
[1:v]scale=${d}:${d}:force_original_aspect_ratio=decrease,setsar=1,pad=${d}:${d}:(ow-iw)/2:(oh-ih)/2,format=yuva420p[cam_rgb];
[cam_rgb][2:v]alphamerge[cam];
[0:v][cam]overlay=main_w-overlay_w-${pad}:main_h-overlay_h-${pad}[vout];
[0:a][1:a]amix=inputs=2:duration=shortest:dropout_transition=2[aout]
" -map "[vout]" -map "[aout]" -shortest \
        -c:v libx264 -crf 28 -preset veryfast \
        -c:a aac -b:a 128k "$output"

    rm -f "$mask"
else
    cp "$screen" "$output"
fi

rm -f "$screen" "$webcam"

wl-copy -t text/uri-list "file://$output"
notify-send "Recording saved" "$(basename "$output")" -i camera-video --action="open=Open folder"
emacsclient -c "$(dirname "$output")"

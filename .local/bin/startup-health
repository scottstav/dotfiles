#!/bin/bash
# Check health of all custom user services and processes after login

# Long-running systemd user services (should stay active)
SERVICES=(
    claude-voice
    claude-hid
    voice-typing
    dropbox
)

# Timer-triggered oneshot services (healthy if timer is active and service hasn't failed)
TIMER_SERVICES=(
    system-freshness
    gcal-refresh
    mbsync
    google-contacts-sync
)

# Processes that should be running (from exec-once)
PROCESSES=(
    waybar
    swaync
    hyprpaper
    hypridle
    kdeconnectd
    emacs
)

failed_services=()
failed_processes=()

# Check long-running services
for svc in "${SERVICES[@]}"; do
    if ! systemctl --user is-active --quiet "$svc.service" 2>/dev/null; then
        failed_services+=("$svc")
    fi
done

# Check timer-triggered oneshot services
for svc in "${TIMER_SERVICES[@]}"; do
    if ! systemctl --user is-active --quiet "$svc.timer" 2>/dev/null; then
        failed_services+=("$svc.timer")
    elif systemctl --user is-failed --quiet "$svc.service" 2>/dev/null; then
        failed_services+=("$svc")
    fi
done

# Check processes
for proc in "${PROCESSES[@]}"; do
    if ! pgrep -x "$proc" >/dev/null 2>&1; then
        failed_processes+=("$proc")
    fi
done

total=$(( ${#SERVICES[@]} + ${#TIMER_SERVICES[@]} + ${#PROCESSES[@]} ))
failed=$(( ${#failed_services[@]} + ${#failed_processes[@]} ))
running=$(( total - failed ))

if [ "$failed" -eq 0 ]; then
    notify-send -a "System" \
        -t 8000 \
        "Startup Health" \
        "All $total services healthy"
    exit 0
fi

all_failed=("${failed_services[@]}" "${failed_processes[@]}")
IFS=', '; names="${all_failed[*]}"; unset IFS

urgency="normal"
[ "$failed" -gt 3 ] && urgency="critical"

# Show notification with Fix button; notify-send -A waits for action
action=$(notify-send -a "System" \
    --urgency="$urgency" \
    -t 0 \
    -A "fix=Fix with Claude" \
    "Startup Health" \
    "$running/$total running — failed: $names")

if [ "$action" = "fix" ]; then
    ccl new --dir "$HOME/dotfiles" --task "The following services/processes failed on startup: ${names}. Fix this and ensure it doesnt happen again."
fi

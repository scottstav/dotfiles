#!/usr/bin/env bash
set -euo pipefail

source "$HOME/.local/share/fzf-picker/theme.sh"

THEME_DIR="$HOME/.config/themes"

SELECTION=$(
    theme list | sed "s/ \*$/ [active]/" \
    | fzf "${FZF_PICKER_OPTS[@]}" \
        --border-label=' Theme ' \
        --prompt='theme> '
) || exit 0

[ -z "$SELECTION" ] && exit 0

# Strip the " [active]" marker if present
NAME="${SELECTION%% \[active\]}"

hyprctl dispatch exec "theme set '$NAME'"

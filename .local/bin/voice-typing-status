#!/bin/bash
# Waybar module for voice typing status

STATE_FILE="${XDG_RUNTIME_DIR:-/tmp}/voice-typing-state"

# Check if mic monitor loopback is active
if systemctl --user is-active --quiet mic-monitor; then
    MON_DOT="<span font_size='x-small' rise='6000'> ●</span>"
    MON_TIP=" | Mic monitor ON (middle-click to stop)"
else
    MON_DOT=""
    MON_TIP=""
fi

if [ ! -f "$STATE_FILE" ]; then
    # Daemon not running
    echo "{\"text\": \"$MON_DOT\", \"class\": \"off\", \"tooltip\": \"Voice typing off (click to start)$MON_TIP\"}"
    exit 0
fi

STATE=$(cat "$STATE_FILE")

case "$STATE" in
    listening)
        echo "{\"text\": \"$MON_DOT\", \"class\": \"listening\", \"tooltip\": \"Voice typing: LISTENING (click to pause)$MON_TIP\"}"
        ;;
    paused)
        echo "{\"text\": \"$MON_DOT\", \"class\": \"paused\", \"tooltip\": \"Voice typing: PAUSED (click to resume)$MON_TIP\"}"
        ;;
    *)
        echo "{\"text\": \"$MON_DOT\", \"class\": \"off\", \"tooltip\": \"Voice typing off$MON_TIP\"}"
        ;;
esac

#!/bin/bash
# Record webcam video with audio. Fzf pickers for device selection, then
# ffmpeg recording with a live mpv preview that includes an audio level meter.
# Press keybind again (or close mpv) to stop recording.

PIDFILE="/tmp/webcam-record.pid"
PATHFILE="/tmp/webcam-record-path"
OUTDIR="$HOME/Dropbox/recordings"

# --- Toggle: stop recording if already running ---

if [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    kill -INT "$(cat "$PIDFILE")"
    exit 0
fi

bold=$'\e[1m'
dim=$'\e[2m'
reset=$'\e[0m'
green=$'\e[32m'

FZF_OPTS=(--ansi --height=100% --layout=reverse --no-info --pointer=">" --no-scrollbar --bind 'left-click:accept')

# --- Phase 1: Device Selection ---

# Webcam picker — parse v4l2-ctl, take first /dev/video per camera (second is metadata)
get_webcams() {
    local current_name="" got_dev=false
    v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
        if [[ "$line" =~ ^[^$'\t'] ]]; then
            current_name=$(echo "$line" | sed 's/ (.*//')
            got_dev=false
        elif [[ "$line" =~ /dev/video ]] && ! $got_dev; then
            local dev
            dev=$(echo "$line" | tr -d '[:space:]')
            got_dev=true
            printf "${bold}%s${reset} ${dim}%s${reset}\t%s\n" "$current_name" "$dev" "$dev"
        fi
    done
}

# Mic picker — reuses audio-switcher's pattern
get_mics() {
    local default_source
    default_source=$(pactl get-default-source 2>/dev/null)
    pactl list sources short | grep -v '\.monitor' | while read -r id name _rest; do
        desc=$(pactl list sources | grep -A1 "Name: $name" | grep "Description:" | sed 's/.*Description: //')
        vol=$(pactl get-source-volume "$name" 2>/dev/null | grep -oP '\d+%' | head -1)
        marker="  "
        [[ "$name" == "$default_source" ]] && marker="${green}*${reset} "
        printf "%s${bold}%s${reset} ${dim}%s${reset}\t%s\n" "$marker" "$desc" "$vol" "$name"
    done
}

webcam_selection=$(get_webcams | fzf "${FZF_OPTS[@]}" \
    --header="${bold}Select webcam${reset}" \
    --delimiter='\t' --with-nth=1)
[[ -z "$webcam_selection" ]] && exit 0
WEBCAM=$(printf '%s' "$webcam_selection" | awk -F'\t' '{print $NF}')

mic_selection=$(get_mics | fzf "${FZF_OPTS[@]}" \
    --header="${bold}Select microphone${reset}" \
    --delimiter='\t' --with-nth=1)
[[ -z "$mic_selection" ]] && exit 0
MIC=$(printf '%s' "$mic_selection" | awk -F'\t' '{print $NF}')

# --- Phase 2: Recording with Live Preview ---

mkdir -p "$OUTDIR"
FILE="$OUTDIR/cam-$(date +%Y%m%d-%H%M%S).mp4"
echo "$FILE" > "$PATHFILE"

# Pipe approach: ffmpeg pipes rawvideo preview to mpv, records x264 to file.
# Subshell + exec captures ffmpeg's actual PID for the toggle keybind.
# - -tune zerolatency: no B-frames or lookahead, minimum encode delay
# - --no-audio on mpv: prevents feedback loop (mic hearing its own playback)
# - --untimed on mpv: display frames immediately, don't pace by timestamps
( echo $BASHPID > "$PIDFILE"; exec ffmpeg \
    -f v4l2 -input_format mjpeg -framerate 30 -i "$WEBCAM" \
    -f pulse -thread_queue_size 1024 -i "$MIC" \
    -filter_complex "[1:a]showvolume=w=320:h=20:o=v[meter];[0:v][meter]overlay=10:main_h-overlay_h-10[preview]" \
    -map 0:v -map 1:a -c:v libx264 -crf 23 -tune zerolatency -preset ultrafast -c:a aac "$FILE" \
    -map "[preview]" -f nut -c:v rawvideo -flush_packets 1 pipe:1 \
) 2>/dev/null | mpv --no-audio --no-cache --profile=low-latency --untimed \
    --video-latency-hacks=yes --title="Webcam Recording" - 2>/dev/null

# --- Cleanup (mpv exited via q/close, or ffmpeg killed via toggle) ---

rm -f "$PIDFILE"

FILE=$(cat "$PATHFILE" 2>/dev/null)
rm -f "$PATHFILE"

if [[ -f "$FILE" ]]; then
    wl-copy -t text/uri-list "file://$FILE"
    systemd-run --user --no-block bash -c \
        'notify-send "Recording saved" "$1" -i camera-video --action="open=Open folder" && emacsclient -c "$2"' \
        _ "$(basename "$FILE")" "$OUTDIR" 2>/dev/null
fi

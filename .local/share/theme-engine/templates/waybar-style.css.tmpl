* {
    border: none;
    border-radius: 0;
    font-family: "Iosevka";
    font-size: 11px;
    min-height: 0;
}

window#waybar {
    min-height: 24px;
    color: ${foreground};
    background: linear-gradient(180deg, rgba(${background_rgba}, 0.6), rgba(${background_rgba}, 0.4));
    border-bottom: 1px solid rgba(${accent_rgba}, 0.25);
    border-radius: 0;
}

#window {
    font-family: "Iosevka";
    color: ${terminal_white};
}

#workspaces button {
    color: ${foreground};
    padding: 0 4px;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
}

#workspaces button:hover {
    color: ${terminal_bright_white};
}

#workspaces button.active {
    color: ${accent};
    border-bottom: 2px solid ${accent};
}

#workspaces button.urgent {
    background-color: rgb(110, 00, 00);
    color: ${terminal_bright_white};
}

#mode {
    background: rgba(${surface_rgba}, 0.5);
    border-bottom: 3px solid ${dim};
}

#custom-waybarstatus {
    margin-left: 150px;
}

.modules-center {
}

.modules-center * {
    padding: 0 1px;
    margin: 0 5px;
}

.modules-right * {
    padding: 0 1px;
    margin: 0 5px;
}

#custom-waybarstatus {
    padding: 2px 4px;
    color: ${terminal_white};
    background-color: rgba(${surface_rgba}, 0.5);
}

#battery icon {
    color: ${error};
}

#battery.charging {
    color: ${success};
}

@keyframes blink {
    to {
	background-color: ${accent_bright};
	color: ${background};
    }
}

#battery.warning:not(.charging) {
    color: ${error};
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

#network.disconnected {
    background: ${error};
}

/* Audio module */
#custom-audio {
    color: ${foreground};
}

#custom-audio.muted {
    color: ${error};
}

#custom-audio.source-muted {
    color: ${error};
}

#custom-audio.high {
    color: ${warning};
}

/* Bluetooth module */
#custom-bluetooth {
    color: ${foreground};
}

#custom-bluetooth.off {
    color: ${border};
}

#custom-bluetooth.on {
    color: ${dim};
}

#custom-bluetooth.connected {
    color: ${accent_bright};
}

#custom-bluetooth.low-battery {
    color: ${warning};
    animation-name: pulse;
    animation-duration: 2s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
}

#custom-spotify {
    color: ${accent_bright};
}

#tray {
    color: ${accent_bright};
}

#custom-sysinfo {
    color: ${accent_bright};
}

#custom-sysinfo.warning {
    color: ${warning};
}

#custom-sysinfo.critical {
    color: ${error};
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

#custom-external-drive {
    color: ${accent_bright};
}

#custom-external-drive.mounted {
    color: ${success};
}

/* Notification module */
#custom-notification {
    color: ${foreground};
}

#custom-notification.notification {
    color: ${accent_bright};
}

#custom-notification.dnd-notification,
#custom-notification.dnd-none {
    color: ${dim};
}

#custom-notification.inhibited-notification,
#custom-notification.inhibited-none {
    color: ${warning};
}

/* Recording module */
#custom-recording {
    color: #404040;
}

#custom-recording.recording {
    color: ${error};
    animation-name: pulse;
    animation-duration: 1s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
}

#custom-recording.idle {
    color: transparent;
    padding: 0;
    margin: 0;
}

/* Voice typing module */
#custom-voice-typing {
    color: ${dim};
}

#custom-voice-typing.listening {
    color: ${success};
    animation-name: pulse;
    animation-duration: 1.5s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
}

#custom-voice-typing.paused {
    color: ${dim};
}

#custom-voice-typing.off {
    color: ${border};
}

@keyframes pulse {
    0% {
        opacity: 1;
    }
    50% {
        opacity: 0.5;
    }
    100% {
        opacity: 1;
    }
}

/* System freshness module */
#custom-system-freshness.fresh {
    color: ${success};
}

#custom-system-freshness.healthy {
    color: ${accent_bright};
}

#custom-system-freshness.aging {
    color: ${warning};
}

#custom-system-freshness.wilting {
    color: ${error};
}

#custom-system-freshness.dead {
    color: ${error};
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

/* Google Calendar module */
#custom-gcal.active {
    color: ${success};
}

#custom-gcal.urgent {
    color: ${error};
    animation-name: blink;
    animation-duration: 0.5s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-direction: alternate;
}

#custom-gcal.soon {
    color: ${warning};
}

#custom-gcal.upcoming {
    color: ${accent_bright};
}

#custom-gcal.later {
    color: ${foreground};
}

#custom-gcal.idle {
    color: ${dim};
}

#custom-gcal.none {
    color: #404040;
}

/* Smooth color glow animations for aside states */
@keyframes glow-blue {
    0% { color: ${accent_bright}; }
    50% { color: ${accent_bright_light}; }
    100% { color: ${accent_bright}; }
}

@keyframes glow-green {
    0% { color: ${success}; }
    50% { color: ${success_light}; }
    100% { color: ${success}; }
}

@keyframes glow-amber {
    0% { color: ${warning}; }
    50% { color: ${warning_light}; }
    100% { color: ${warning}; }
}

/* Aside module */
#custom-aside {
    color: ${accent_bright};
}

#custom-aside.thinking {
    animation-name: glow-blue;
    animation-duration: 1.5s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
}

#custom-aside.tool_use {
    animation-name: glow-amber;
    animation-duration: 1s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
}

#custom-aside.speaking {
    animation-name: glow-green;
    animation-duration: 1s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
}

#custom-aside.listening {
    color: ${warning};
    animation-name: pulse;
    animation-duration: 0.8s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
}

/* CCL worker module */
#custom-ccl {
    color: ${accent_bright};
}

#custom-ccl.idle {
    color: ${dim};
}

@keyframes glow-yellow {
    0% { color: ${terminal_yellow}; opacity: 1; }
    50% { color: #7c6f3e; opacity: 0.5; }
    100% { color: ${terminal_yellow}; opacity: 1; }
}

#custom-ccl.working {
    animation-name: glow-yellow;
    animation-duration: 2s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
}

@keyframes arrive-green {
    0% { color: #ffffff; }
    30% { color: ${success}; }
    60% { color: #ffffff; }
    100% { color: ${success}; }
}

#custom-ccl.done {
    color: ${success};
    animation-name: arrive-green;
    animation-duration: 1.5s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: 1;
}

#custom-ccl.pending {
    color: ${dim};
}
